{
  "permissions": {
    "defaultMode": "default"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"E:/claude-config\" 2>/dev/null && { bash sync-from-machine.sh >/dev/null 2>&1; git add -A >/dev/null 2>&1; git diff --cached --quiet || { git commit -m \"Auto-sync Claude Code config\" >/dev/null 2>&1 && git push origin main >/dev/null 2>&1; }; }; true",
            "shell": "bash",
            "timeout": 120,
            "statusMessage": "Syncing Claude config...",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f 'C:/Users/PC/.orca/agent-hooks/claude-hook.cmd' ]; then 'C:/Users/PC/.orca/agent-hooks/claude-hook.cmd'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f 'C:/Users/PC/.orca/agent-hooks/claude-hook.cmd' ]; then 'C:/Users/PC/.orca/agent-hooks/claude-hook.cmd'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f 'C:/Users/PC/.orca/agent-hooks/claude-hook.cmd' ]; then 'C:/Users/PC/.orca/agent-hooks/claude-hook.cmd'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f 'C:/Users/PC/.orca/agent-hooks/claude-hook.cmd' ]; then 'C:/Users/PC/.orca/agent-hooks/claude-hook.cmd'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f 'C:/Users/PC/.orca/agent-hooks/claude-hook.cmd' ]; then 'C:/Users/PC/.orca/agent-hooks/claude-hook.cmd'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f 'C:/Users/PC/.orca/agent-hooks/claude-hook.cmd' ]; then 'C:/Users/PC/.orca/agent-hooks/claude-hook.cmd'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f 'C:/Users/PC/.orca/agent-hooks/claude-hook.cmd' ]; then 'C:/Users/PC/.orca/agent-hooks/claude-hook.cmd'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f 'C:/Users/PC/.orca/agent-hooks/claude-hook.cmd' ]; then 'C:/Users/PC/.orca/agent-hooks/claude-hook.cmd'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f 'C:/Users/PC/.orca/agent-hooks/claude-hook.cmd' ]; then 'C:/Users/PC/.orca/agent-hooks/claude-hook.cmd'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f 'C:/Users/PC/.orca/agent-hooks/claude-hook.cmd' ]; then 'C:/Users/PC/.orca/agent-hooks/claude-hook.cmd'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true,
    "watch@claude-video": true,
    "understand-anything@understand-anything": true,
    "agentmemory@agentmemory": true
  },
  "extraKnownMarketplaces": {
    "claude-video": {
      "source": {
        "source": "github",
        "repo": "bradautomates/claude-video"
      }
    },
    "understand-anything": {
      "source": {
        "source": "github",
        "repo": "Lum1104/Understand-Anything"
      }
    },
    "agentmemory": {
      "source": {
        "source": "github",
        "repo": "rohitg00/agentmemory"
      }
    }
  },
  "effortLevel": "high",
  "autoUpdatesChannel": "latest"
}
